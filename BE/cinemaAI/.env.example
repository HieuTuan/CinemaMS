# Copy this file to your local environment settings, then fill real values.
# Spring Boot loads .env from the project root when it exists.
# You can also set these values in IntelliJ Run Configuration, PowerShell, Docker, or your deployment environment.

# Database
DB_URL=jdbc:postgresql://localhost:5432/cinema_ai
DB_USERNAME=postgres
DB_PASSWORD=123456

# OpenAI / Spring AI
# Keep dummy value for local runs that do not call real OpenAI APIs.
OPENAI_API_KEY=dummy-openai-key

# Gmail SMTP / OTP email
# Keep MAIL_ENABLED=false for local Postman testing if you do not want to send real emails.
# To send through Gmail, use a Google App Password, not your normal Gmail password.
MAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-gmail@gmail.com
MAIL_PASSWORD=your-google-app-password
MAIL_FROM=your-gmail@gmail.com
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true

# JWT
# Local can use this sample value. Production should use a long random secret.
JWT_SECRET=cineai-local-secret-key-change-me-1234567890
JWT_ACCESS_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# Google OAuth
# Required for POST /api/v1/auth/google.
GOOGLE_CLIENT_ID=316168245134-0oda35k7fpifvgq2fgv0k66ifuq0omko.apps.googleusercontent.com
