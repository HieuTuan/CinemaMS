flowchart LR
    %% CinemaAI current BE conceptual entity flowchart
    %% Paste into Draw.io: Insert > Advanced > Mermaid

    subgraph AUTH["Identity / Auth"]
        User[User]
        Role[Role]
        UserRole[UserRole]
        RefreshToken[RefreshToken]
        EmailVerificationToken[EmailVerificationToken]
        PhoneVerificationToken[PhoneVerificationToken]
        PasswordResetToken[PasswordResetToken]
        PendingRegistration[PendingRegistration]
        Notification[Notification]
    end

    subgraph MOVIE["Movie Catalog / AI"]
        Movie[Movie]
        Genre[Genre]
        MovieGenre[MovieGenre]
        Wishlist[Wishlist]
        Review[Review]
        AIAnalysis[AIAnalysis]
        AIEmotionSegment[AIEmotionSegment]
    end

    subgraph CINEMA["Cinema / Schedule"]
        Cinema[Cinema]
        Room[Room]
        Seat[Seat]
        Showtime[Showtime]
    end

    subgraph BOOKING["Booking / Commerce"]
        Booking[Booking]
        BookingSeat[BookingSeat]
        Payment[Payment]
        Promotion[Promotion]
        BookingPromotion[BookingPromotion]
        FoodItem[FoodItem]
        FoodCombo[FoodCombo]
        BookingFoodItem[BookingFoodItem]
        LoyaltyPoint[LoyaltyPoint]
    end

    subgraph STAFF["Staff / Audit / File"]
        StaffProfile[StaffProfile]
        StaffShift[StaffShift]
        AuditLog[AuditLog]
        UploadedFile[UploadedFile]
    end

    User -->|1..*| UserRole
    Role -->|1..*| UserRole
    User -->|1..*| RefreshToken
    User -->|1..*| EmailVerificationToken
    User -->|1..*| PhoneVerificationToken
    User -->|1..*| PasswordResetToken
    User -->|1..*| Notification

    Movie -->|1..*| MovieGenre
    Genre -->|1..*| MovieGenre
    User -->|1..*| Wishlist
    Movie -->|1..*| Wishlist
    User -->|1..*| Review
    Movie -->|1..*| Review
    Booking -->|0..*| Review
    Movie -->|1..*| AIAnalysis
    User -->|0..* approved_by| AIAnalysis
    AIAnalysis -->|1..*| AIEmotionSegment

    Cinema -->|1..*| Room
    Room -->|1..*| Seat
    Room -->|1..*| Showtime
    Movie -->|1..*| Showtime

    User -->|1..*| Booking
    Showtime -->|1..*| Booking
    Booking -->|1..*| BookingSeat
    Showtime -->|1..*| BookingSeat
    Seat -->|1..*| BookingSeat
    Booking -->|1..*| Payment
    Booking -->|0..*| BookingPromotion
    Promotion -->|1..*| BookingPromotion
    Booking -->|0..*| BookingFoodItem
    FoodItem -->|0..*| BookingFoodItem
    FoodCombo -->|0..*| BookingFoodItem
    User -->|1..*| LoyaltyPoint
    Booking -->|0..*| LoyaltyPoint

    User -->|0..1| StaffProfile
    Cinema -->|0..*| StaffProfile
    StaffProfile -->|1..*| StaffShift
    User -->|0..* actor| AuditLog
    User -->|0..* uploaded_by| UploadedFile

    classDef auth fill:#DBEAFE,stroke:#2563EB,color:#111827
    classDef movie fill:#DCFCE7,stroke:#16A34A,color:#111827
    classDef cinema fill:#FFEDD5,stroke:#EA580C,color:#111827
    classDef booking fill:#FEF9C3,stroke:#CA8A04,color:#111827
    classDef staff fill:#EDE9FE,stroke:#7C3AED,color:#111827

    class User,Role,UserRole,RefreshToken,EmailVerificationToken,PhoneVerificationToken,PasswordResetToken,PendingRegistration,Notification auth
    class Movie,Genre,MovieGenre,Wishlist,Review,AIAnalysis,AIEmotionSegment movie
    class Cinema,Room,Seat,Showtime cinema
    class Booking,BookingSeat,Payment,Promotion,BookingPromotion,FoodItem,FoodCombo,BookingFoodItem,LoyaltyPoint booking
    class StaffProfile,StaffShift,AuditLog,UploadedFile staff
